
# URL del backend desplegado (SIN trailing slash, SIN /api)
# BACKEND_URL=http://localhost:8000

# Clave secreta compartida con el backend (WORKER_SECRET_KEY en Render)
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
WORKER_SECRET_KEY=PEGA_AQUI_UN_SECRETO_LARGO

# --- Archivos ---
MAX_UPLOAD_SIZE_MB=300

# --- Whisper (transcripcion de audio) ---
# Modelo: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL_SIZE=medium
# Dispositivo: auto | cuda | cpu
WHISPER_DEVICE=cuda
# Tipo de computo - GPU: float16, int8_float16, int8 | CPU: int8, float32
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_LANGUAGE=es

# Parámetros de precision
WHISPER_TEMPERATURE=0.0
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_COMPRESSION_RATIO=2.0
WHISPER_NO_SPEECH_THRESHOLD=0.7
WHISPER_REPETITION_PENALTY=1.1

# Chunking de audio largo
CHUNK_DURATION_MINUTES=5
CHUNK_OVERLAP_SECONDS=30
MAX_PARALLEL_CHUNKS=2
MAX_CONCURRENT_TRANSCRIPTIONS=1
WHISPER_BATCH_SIZE=16

# VAD (Voice Activity Detection)
VAD_FILTER_ENABLED=true
VAD_MIN_SPEECH_DURATION_MS=250
VAD_SPEECH_PAD_MS=400

# Timeout para transcripciones largas (segundos)
TRANSCRIPTION_TIMEOUT=1800

# --- IA (resumenes) ---
SUMMARY_PROVIDER=gemini
AI_TEMPERATURE=0.1
AI_REQUEST_TIMEOUT=120


# Gemini (default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=6144
GEMINI_MAX_ATTEMPTS=2
MAX_TRANSCRIPT_SIZE_SINGLE=150000

# Ollama (opcional, local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ENABLED=true
OLLAMA_NUM_PREDICT=2300

#Dropbox (Para almacenamiento temporal de audios pesados)
AUDIO_STORAGE_BACKEND=dropbox
DROPBOX_ACCESS_TOKEN=
DROPBOX_AUDIO_ROOT_PATH=/M4A-Audio-Temp

AI_CHUNK_MAX_CHARS=60000
GROQ_CHUNK_MAX_CHARS=8000
GROQ_SAFE_PROMPT_CHARS=10000
POLL_INTERVAL_SECONDS=10
SUMMARY_TARGET_WORDS_MIN=2000
SUMMARY_TARGET_WORDS_MAX=3000
LOG_LEVEL=DEBUG