# Worker -> Backend
BACKEND_URL=http://localhost:8000
WORKER_SECRET_KEY=replace-with-your-worker-key
POLL_INTERVAL_SECONDS=10

# Whisper
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
WHISPER_LANGUAGE=es
WHISPER_COMPRESSION_RATIO=2.0
WHISPER_NO_SPEECH_THRESHOLD=0.7
WHISPER_REPETITION_PENALTY=1.1
VAD_FILTER_ENABLED=true
VAD_MIN_SILENCE_DURATION_MS=250
VAD_SPEECH_PAD_MS=400

# AI Provider
# Valores admitidos: gemini | groq | disabled
SUMMARY_PROVIDER=gemini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_REQUEST_DELAY=2.5
AI_TEMPERATURE=0.1
AI_REQUEST_TIMEOUT=120
MAX_TRANSCRIPT_SIZE_SINGLE=15000
AI_CHUNK_MAX_CHARS=12000
GROQ_CHUNK_MAX_CHARS=8000
GROQ_SAFE_PROMPT_CHARS=10000

# Logging
LOG_LEVEL=INFO
